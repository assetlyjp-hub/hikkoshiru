{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "category": {
      "type": "string",
      "enum": [
        "company",
        "estimate",
        "cost",
        "tips"
      ]
    },
    "tags": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "publishedAt": {
      "type": "string"
    },
    "updatedAt": {
      "type": "string"
    },
    "draft": {
      "default": false,
      "type": "boolean"
    },
    "relatedServices": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "articleType": {
      "default": "guide",
      "type": "string",
      "enum": [
        "comparison",
        "review",
        "guide"
      ]
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "description",
    "category",
    "publishedAt"
  ]
}