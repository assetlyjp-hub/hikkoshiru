---
// 動的ルーティング: /articles/{slug} で記事を表示
// Content Collections から記事を取得し、Article レイアウトで描画する
//
// [...slug] は「キャッチオールルート」と呼ばれ、
// 例えば /articles/moving-cost-average/ のようなURLを自動生成する
import { getCollection, render } from 'astro:content';
import Article from '../../layouts/Article.astro';

// 静的パス生成（ビルド時に全記事のURLパスを列挙する）
export async function getStaticPaths() {
  // 下書き（draft: true）以外の全記事を取得
  const articles = await getCollection('articles', ({ data }) => {
    return !data.draft;
  });

  // 各記事のURL（slug）とデータをマッピング
  return articles.map((article) => ({
    params: { slug: article.id },  // URLパラメータ
    props: { article },            // ページに渡すデータ
  }));
}

// ページに渡されたデータを取得
const { article } = Astro.props;
// Markdown → HTMLに変換
const { Content } = await render(article);
// frontmatterのデータを展開
const { title, description, publishedAt, updatedAt, category, tags, articleType } = article.data;
---

<Article
  title={title}
  description={description}
  publishedAt={publishedAt}
  updatedAt={updatedAt}
  category={category}
  tags={tags}
  articleType={articleType}
>
  <Content />
</Article>
